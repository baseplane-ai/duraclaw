#!/bin/bash
# Pre-commit hook for Duraclaw
# Fast checks only: lint staged files + typecheck (cached)

set -e

echo "Running pre-commit checks..."
echo ""

if [ ! -f "package.json" ]; then
  echo "Error: Must run from project root"
  exit 1
fi

# =============================================================================
# Phase 0: Reject commits with unstaged changes (prevents confusion)
# =============================================================================

if ! git diff --quiet; then
  echo "Error: You have unstaged changes."
  echo ""
  echo "This can cause confusion where committed code differs from your working copy."
  echo ""
  echo "Options:"
  echo "  git add -u              # Stage all changes to tracked files"
  echo "  git add -A              # Stage all changes including new files"
  echo "  git stash               # Temporarily stash unstaged changes"
  echo "  git commit --no-verify  # Skip this check (not recommended)"
  echo ""
  exit 1
fi

# =============================================================================
# Phase 1: Biome checks on STAGED files only (fast!)
# =============================================================================

echo "Running Biome on staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json)$' | grep -v 'routeTree\.gen\.ts' | grep -v '\.config\.' || true)

if [ -n "$STAGED_FILES" ]; then
  if ! echo "$STAGED_FILES" | xargs pnpm biome check --error-on-warnings; then
    echo ""
    echo "Biome checks failed! Fix errors or run 'pnpm biome check --write'"
    echo "To skip (not recommended): git commit --no-verify"
    exit 1
  fi
  echo "Biome checks passed"
else
  echo "No staged JS/TS files to lint"
fi
echo ""

# =============================================================================
# Phase 2: Type checking (turbo caches unchanged packages - fast on repeat)
# =============================================================================

echo "Running type check..."
if ! pnpm typecheck; then
  echo ""
  echo "Type checking failed! Fix errors above"
  echo "To skip (not recommended): git commit --no-verify"
  exit 1
fi

echo "Type checking passed"
echo ""

echo "All pre-commit checks passed! Proceeding with commit..."
