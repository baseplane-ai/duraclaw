{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": { "includes": ["**", "!!**/dist"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true },
    "includes": [
      "**",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/.turbo/**",
      "!**/*.config.ts",
      "!**/*.config.js",
      "!**/*.config.mjs",
      "!**/*.test.ts",
      "!**/*.spec.ts",
      "!**/*.d.ts"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "warn",
            "noUnusedImports": "warn"
          },
          "style": {
            "useConst": "error",
            "useNodejsImportProtocol": "warn",
            "useTemplate": "warn"
          },
          "suspicious": {
            "noConsole": "off",
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
