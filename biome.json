{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": { "includes": ["**", "!!**/dist"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true },
    "includes": [
      "**",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/.turbo/**",
      "!**/*.config.ts",
      "!**/*.config.js",
      "!**/*.config.mjs",
      "!**/*.test.ts",
      "!**/*.spec.ts",
      "!**/*.d.ts"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "overrides": [
    {
      "includes": [
        "apps/orchestrator/src/components/ui/**",
        "apps/orchestrator/src/components/command-menu.tsx",
        "apps/orchestrator/src/assets/**",
        "apps/orchestrator/src/lib/cookies.ts",
        "packages/ai-elements/src/**"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off",
            "useAriaPropsForRole": "off",
            "useFocusableInteractive": "off",
            "useSemanticElements": "off",
            "useAnchorContent": "off"
          },
          "complexity": {
            "useOptionalChain": "off"
          },
          "suspicious": {
            "noDocumentCookie": "off",
            "noArrayIndexKey": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "warn",
            "noUnusedImports": "warn"
          },
          "style": {
            "useConst": "error",
            "useNodejsImportProtocol": "warn",
            "useTemplate": "warn"
          },
          "suspicious": {
            "noConsole": "off",
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/orchestrator/src/native/**",
        "apps/orchestrator/src/db/persistence-op-sqlite.ts",
        "apps/orchestrator/src/lib/auth-client-expo.ts",
        "apps/orchestrator/src/features/kanban/KanbanBoard.tsx",
        "apps/orchestrator/src/features/kanban/KanbanBoardNative.tsx",
        "apps/orchestrator/src/entry-rn.tsx",
        "apps/orchestrator/src/lib/connection-manager/lifecycle.ts",
        "apps/orchestrator/src/lib/native-push-deep-link.ts",
        "apps/orchestrator/src/hooks/use-push-subscription-native.ts",
        "packages/ai-elements/src/components/canvas.tsx",
        "packages/ai-elements/src/components/jsx-preview.tsx",
        "packages/ai-elements/src/components/persona.tsx",
        "packages/ai-elements/src/components/audio-player.tsx",
        "packages/ai-elements/src/components/conversation.tsx",
        "packages/ai-elements/src/ui/command.tsx",
        "packages/ai-elements/src/ui/carousel.tsx",
        "packages/op-sqlite-tanstack-persistence/**"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "useHookAtTopLevel": "off"
          },
          "style": {
            "noCommonJs": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/orchestrator/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@xyflow/react": "Banned in apps/orchestrator/src/** until P3 lands feature gates / replacements (GH#131 / GH#132). packages/ai-elements/** remains free to export.",
                  "react-jsx-parser": "Banned in apps/orchestrator/src/** until P3 lands feature gates / replacements (GH#131 / GH#132). packages/ai-elements/** remains free to export.",
                  "@rive-app/react-webgl2": "Banned in apps/orchestrator/src/** until P3 lands feature gates / replacements (GH#131 / GH#132). packages/ai-elements/** remains free to export.",
                  "media-chrome": "Banned in apps/orchestrator/src/** until P3 lands feature gates / replacements (GH#131 / GH#132). packages/ai-elements/** remains free to export."
                }
              }
            }
          }
        }
      }
    }
  ]
}
