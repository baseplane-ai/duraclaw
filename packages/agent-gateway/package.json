{
  "name": "@duraclaw/agent-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "serve": "bun run src/server.ts",
    "deploy": "sudo systemctl restart duraclaw-agent-gateway"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "@duraclaw/shared-types": "workspace:*",
    "@openai/codex-sdk": "0.120.0",
    "@opencode-ai/sdk": "^1.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "bun-types": "^1.3.11",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3",
    "undici-types": "^7.24.6",
    "vitest": "^4.1.2"
  }
}
