{
  "name": "@duraclaw/agent-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash ../../scripts/bundle-bin.sh src/server.ts dist/server.js",
    "dev": "bun run src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "serve": "bun run src/server.ts",
    "deploy": "sudo systemctl restart duraclaw-agent-gateway"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "@duraclaw/docs-runner": "workspace:*",
    "@duraclaw/session-runner": "workspace:*",
    "@duraclaw/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "bun-types": "^1.3.11",
    "typescript": "~5.8.3",
    "undici-types": "^7.24.6",
    "vitest": "^4.1.2"
  }
}
