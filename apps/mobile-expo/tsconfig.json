{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "~/*": ["../orchestrator/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../orchestrator/src/**/*.ts", "../orchestrator/src/**/*.tsx"],
  "exclude": ["node_modules", "android", "ios", ".expo"]
}
