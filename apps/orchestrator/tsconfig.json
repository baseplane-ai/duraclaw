{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "~/*": ["./src/*"]
    },
    "composite": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "worker-configuration.d.ts"],
  "exclude": ["node_modules", "dist", ".output", ".wrangler", "src/routeTree.gen.ts", "src/routes"]
}
