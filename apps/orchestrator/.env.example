# apps/orchestrator/.env.example
#
# Copy this to apps/orchestrator/.env for local drizzle-kit usage.
# Never commit .env. Production secrets are managed via `wrangler secret put`,
# NOT via this file.

# ─── drizzle-kit (local schema tooling only) ──────────────────────────────
#
# These are read by drizzle.config.ts when you run `pnpm db:generate`,
# `pnpm db:check`, `pnpm db:studio`, etc. They are NEVER read by the
# deployed worker — the worker reads its D1 binding from wrangler.toml.

# Required for `drizzle-kit generate` and `drizzle-kit check`.
# These commands DO NOT connect to a database; they only diff the schema
# against the local snapshot, so any non-empty placeholder works
# (e.g. `00000000-0000-0000-0000-000000000000`).
#
# For `drizzle-kit studio` and `drizzle-kit push` — which DO connect over
# the d1-http driver — this MUST point at a dev/staging D1 database.
# Pointing it at the prod id (the one in wrangler.toml) and running
# `studio` or `push` will mutate production. Don't.
D1_DATABASE_ID=

# Required for any drizzle-kit command that connects to D1 (studio, push).
# Same staging-only warning as D1_DATABASE_ID.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Runtime auth secrets (DO NOT set here in production) ─────────────────
#
# These belong in `wrangler secret put` for prod. Listing them here only so
# developers know they exist when wiring up a local miniflare/.dev.vars.

# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=

# ─── Gateway integration (DO NOT set here in production) ──────────────────
#
# Same wrangler-secret rule applies. The gateway-side counterpart of these
# values lives in /etc/duraclaw/agent-gateway.env on the VPS.

# CC_GATEWAY_URL=
# CC_GATEWAY_SECRET=
# WORKER_PUBLIC_URL=

# ─── Cutover-only ──────────────────────────────────────────────────────────
#
# MAINTENANCE_MODE is toggled via `wrangler secret put MAINTENANCE_MODE`
# during the production cutover (scripts/cutover.sh). Values: "0" or "1".
# Do NOT set it in this file — it would be unused locally and confusing.

# MAINTENANCE_MODE=0

# Placeholder for the future admin dump endpoint that will replace the
# manual curl flow in scripts/dump-my-state.sh. Tracked as a follow-up
# issue (see scripts/README.md → Cutover rehearsal).

# ADMIN_DUMP_TOKEN=

# Copy this file to .env for local drizzle-kit; never commit .env.
