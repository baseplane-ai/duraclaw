# pnpm hoist patterns for the RN/Expo ecosystem.
#
# Why: Metro (apps/mobile-expo) resolves modules from
# apps/mobile-expo/node_modules and the workspace root node_modules ONLY.
# pnpm's default isolation puts transitives under .pnpm/<hash>/node_modules
# which Metro can't see, causing "Unable to resolve module ..." failures
# at :app:createBundleReleaseJsAndAssets time (fixed during VP-11
# verification of GH#132 P3).
#
# public-hoist-pattern hoists the matching deps to the workspace root
# node_modules so Metro's standard lookup walk finds them. Doesn't
# affect orchestrator's Vite resolver — Vite has its own resolution
# and is fine with the .pnpm tree.
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=@react-navigation/*
public-hoist-pattern[]=hoist-non-react-statics
public-hoist-pattern[]=invariant
public-hoist-pattern[]=nullthrows
public-hoist-pattern[]=prop-types
public-hoist-pattern[]=use-sync-external-store
public-hoist-pattern[]=fbjs
public-hoist-pattern[]=memoize-one
public-hoist-pattern[]=react-is
public-hoist-pattern[]=scheduler
public-hoist-pattern[]=tslib
public-hoist-pattern[]=fast-deep-equal
public-hoist-pattern[]=base64-js
public-hoist-pattern[]=event-target-shim
public-hoist-pattern[]=abort-controller
public-hoist-pattern[]=warn-once
public-hoist-pattern[]=deprecated-react-native-prop-types
public-hoist-pattern[]=whatwg-fetch
public-hoist-pattern[]=whatwg-url-without-unicode
public-hoist-pattern[]=whatwg-url
public-hoist-pattern[]=tr46
public-hoist-pattern[]=punycode
public-hoist-pattern[]=expo*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=@tanstack/*
public-hoist-pattern[]=better-auth
public-hoist-pattern[]=@better-auth/*
public-hoist-pattern[]=better-auth-capacitor
public-hoist-pattern[]=@capacitor/*
public-hoist-pattern[]=@capgo/*
public-hoist-pattern[]=zod
public-hoist-pattern[]=zustand
public-hoist-pattern[]=immer
public-hoist-pattern[]=yjs
public-hoist-pattern[]=y-*
public-hoist-pattern[]=jose
public-hoist-pattern[]=js-cookie
public-hoist-pattern[]=@noble/*
public-hoist-pattern[]=@journeyapps/*
