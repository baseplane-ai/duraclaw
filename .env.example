# CC Gateway
ANTHROPIC_API_KEY=
CC_GATEWAY_API_TOKEN=
CC_GATEWAY_PORT=9877
WORKTREE_PATTERNS=baseplane

# Orchestrator → Gateway connection (set as wrangler secrets)
CC_GATEWAY_URL=wss://your-tunnel-hostname.example.com
CC_GATEWAY_SECRET=same-as-CC_GATEWAY_API_TOKEN

# Better Auth (set as wrangler secret)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-orchestrator.workers.dev
