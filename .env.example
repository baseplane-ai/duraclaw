# ============================================================================
# Duraclaw — Local Development Environment
# ============================================================================
#
# SETUP:
#   cp .env.example .env   # then fill in secrets below
#   # OR run: scripts/setup-clone.sh (does this + generates .dev.vars)
#
# RULES:
#   - .env is gitignored — never commit it
#   - .dev.vars is GENERATED by scripts/verify/dev-up.sh — never hand-edit
#   - Do NOT set CC_GATEWAY_PORT here (see "Port derivation" below)
#
# ============================================================================

# ---------------------------------------------------------------------------
# Cloudflare (only needed for wrangler deploy — not local dev)
# ---------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Gateway secrets (shared between gateway + orchestrator)
# ---------------------------------------------------------------------------

# Bearer token the orchestrator sends to the gateway.
# Gateway validates with timing-safe compare.
CC_GATEWAY_API_TOKEN=

# ---------------------------------------------------------------------------
# Port derivation (READ THIS)
# ---------------------------------------------------------------------------
#
# Each worktree auto-derives a unique port pair from its absolute path:
#   Orchestrator:  43000 + (cksum % 800)  → range 43000–43799
#   Gateway:        9800 + (cksum % 800)  → range  9800–10599
#
# This means you can clone N worktrees and `dev-up.sh` in each one without
# port collisions — no manual allocation needed.
#
# DO NOT set CC_GATEWAY_PORT=9877 here. That's the production gateway port.
# If you need a manual override, use VERIFY_GATEWAY_PORT or VERIFY_ORCH_PORT
# in this file — those are the correct per-worktree override knobs.
#
# VERIFY_ORCH_PORT=43200        # override orchestrator port (optional)
# VERIFY_GATEWAY_PORT=10000     # override gateway port (optional)

# ---------------------------------------------------------------------------
# Gateway project resolution
# ---------------------------------------------------------------------------
# Comma-separated path prefixes the gateway accepts for project/worktree
# dispatch. Leave unset to accept all git repos under /data/projects/.
# WORKTREE_PATTERNS=duraclaw
# PROJECT_PATTERNS=duraclaw

# ---------------------------------------------------------------------------
# Admin user (used by scripts/seed-admin.sh)
# ---------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Bootstrap token (user seeding for verify sessions)
# ---------------------------------------------------------------------------
# Enables POST /api/bootstrap to create test users without sign-up.
# Required for axi-dual-login.sh and verify-mode user seeding.
# Delete after initial bootstrapping in production.
BOOTSTRAP_TOKEN=

# ---------------------------------------------------------------------------
# Codex adapter credentials (GH#107)
# ---------------------------------------------------------------------------
# Required when running sessions with `agent: 'codex'`. The session-runner
# checks for OPENAI_API_KEY before instantiating @openai/codex-sdk; if unset,
# the codex spawn fails fast with a missing-credential error event.
# Claude sessions are unaffected.
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Debug endpoints (dev-only)
# ---------------------------------------------------------------------------
# Set to 1 to enable POST /debug/reap and other debug routes on the gateway.
# DURACLAW_DEBUG_ENDPOINTS=1
